 "cells": [
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "# 神经投射数据热图绘制 - Jupyter Notebook\n",
    "\n",
    "本Notebook演示如何使用Python绘制类似Gou et al., Cell 2025 Figure 2a的热图"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 1. 导入必要的包"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "import pandas as pd\n",
    "import numpy as np\n",
    "import matplotlib.pyplot as plt\n",
    "import seaborn as sns\n",
    "from scipy.cluster.hierarchy import linkage, dendrogram\n",
    "from scipy.spatial.distance import pdist\n",
    "import matplotlib.patches as mpatches\n",
    "from matplotlib.colors import LinearSegmentedColormap\n",
    "\n",
    "# 设置图形样式\n",
    "plt.style.use('seaborn-v0_8-whitegrid')\n",
    "%matplotlib inline"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 2. 读取数据"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# 读取Excel文件\n",
    "file_path = 'neuron_projection_data.xlsx'\n",
    "\n",
    "df_projection = pd.read_excel(file_path, sheet_name='Projection_Data', index_col=0)\n",
    "df_metadata = pd.read_excel(file_path, sheet_name='Metadata')\n",
    "df_regions = pd.read_excel(file_path, sheet_name='Region_Info')\n",
    "\n",
    "print(f"投射矩阵: {df_projection.shape}")\n",
    "print(f"元数据: {df_metadata.shape}")\n",
    "print(f"脑区信息: {df_regions.shape}")"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 3. 数据预览"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# 查看投射矩阵\n",
    "df_projection.head(10)"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# 查看元数据\n",
    "df_metadata.head(10)"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 4. 简单热图 (使用seaborn)"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# 创建简单热图\n",
    "plt.figure(figsize=(14, 10))\n",
    "sns.heatmap(df_projection, cmap='Blues', xticklabels=True, yticklabels=True)\n",
    "plt.title('Projection Strength Heatmap', fontsize=14, fontweight='bold')\n",
    "plt.xlabel('Brain Regions', fontsize=12)\n",
    "plt.ylabel('Neuron Subtypes', fontsize=12)\n",
    "plt.xticks(rotation=45, ha='right')\n",
    "plt.tight_layout()\n",
    "plt.show()"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 5. 带聚类的热图"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# 创建Type颜色映射\n",
    "type_colors = {\n",
    "    'ITc': '#4DAF4A',\n",
    "    'ITs': '#984EA3',\n",
    "    'CT': '#FF7F00',\n",
    "    'PT': '#E41A1C',\n",
    "    'ITi': '#377EB8'\n",
    "}\n",
    "\n",
    "# 为行添加颜色\n",
    "df_metadata_indexed = df_metadata.set_index('Subtype')\n",
    "row_colors = df_metadata_indexed.loc[df_projection.index, 'Type'].map(type_colors)\n",
    "\n",
    "# 绘制聚类热图\n",
    "g = sns.clustermap(\n",
    "    df_projection,\n",
    "    cmap='Blues',\n",
    "    row_colors=row_colors,\n",
    "    figsize=(16, 12),\n",
    "    dendrogram_ratio=0.15,\n",
    "    cbar_pos=(0.02, 0.8, 0.03, 0.15),\n",
    "    linewidths=0\n",
    ")\n",
    "\n",
    "plt.setp(g.ax_heatmap.get_xticklabels(), rotation=45, ha='right')\n",
    "plt.show()"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 6. 投射强度分布"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# 将数据转换为长格式\n",
    "df_long = df_projection.reset_index().melt(\n",
    "    id_vars=['Subtype'],\n",
    "    var_name='Region',\n",
    "    value_name='LogLength'\n",
    ")\n",
    "\n",
    "# 合并Type信息\n",
    "df_long = df_long.merge(df_metadata[['Subtype', 'Type']], on='Subtype')\n",
    "\n",
    "# 绘制箱线图\n",
    "plt.figure(figsize=(10, 6))\n",
    "sns.boxplot(data=df_long, x='Type', y='LogLength', palette=type_colors)\n",
    "plt.title('Projection Strength Distribution by Type', fontsize=14, fontweight='bold')\n",
    "plt.xlabel('Neuron Type', fontsize=12)\n",
    "plt.ylabel('Log Axon Length', fontsize=12)\n",
    "plt.tight_layout()\n",
    "plt.show()"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 7. 按Type分组的子热图"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# 为每个Type创建子热图\n",
    "types = df_metadata['Type'].unique()\n",
    "\n",
    "fig, axes = plt.subplots(2, 3, figsize=(18, 12))\n",
    "axes = axes.flatten()\n",
    "\n",
    "for i, t in enumerate(types):\n",
    "    if i >= len(axes):\n",
    "        break\n",
    "    \n",
    "    # 获取该Type的亚型\n",
    "    subtypes = df_metadata[df_metadata['Type'] == t]['Subtype'].values\n",
    "    \n",
    "    if len(subtypes) > 0:\n",
    "        sub_data = df_projection.loc[subtypes]\n",
    "        \n",
    "        # 只保留有投射的脑区\n",
    "        sub_data = sub_data.loc[:, sub_data.sum() > 0]\n",
    "        \n",
    "        sns.heatmap(sub_data, ax=axes[i], cmap='Blues', cbar=True)\n",
    "        axes[i].set_title(f'Type {t} (n={len(subtypes)})', fontsize=12, fontweight='bold')\n",
    "        axes[i].set_xlabel('')\n",
    "        axes[i].set_ylabel('')\n",
    "\n",
    "# 隐藏多余的子图\n",
    "for j in range(i+1, len(axes)):\n",
    "    axes[j].axis('off')\n",
    "\n",
    "plt.suptitle('Projection Patterns by Type', fontsize=16, fontweight='bold')\n",
    "plt.tight_layout()\n",
    "plt.show()"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 8. 保存结果"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# 保存热图为PDF\n",
    "g = sns.clustermap(\n",
    "    df_projection,\n",
    "    cmap='Blues',\n",
    "    row_colors=row_colors,\n",
    "    figsize=(16, 12)\n",
    ")\n",
    "g.savefig('heatmap_output.pdf', dpi=300, bbox_inches='tight')\n",
    "g.savefig('heatmap_output.png', dpi=150, bbox_inches='tight')\n",
    "print("✅ 热图已保存")"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "---\n",
    "\n",
    "**提示：** 如需更高质量的图形，建议使用R语言的ComplexHeatmap包！"
   ]
  }
