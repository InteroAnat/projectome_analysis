column_title = title,
column_title_gp = gpar(fontsize = 16, fontface = "bold"),
show_heatmap_legend = FALSE,
padding = unit(c(15, 5, 25, 50), "mm"))
# 5. 侧边装饰线
side_colors <- c("IPSI" = "#377EB8", "CONTRA" = "#E41A1C")
for(nm in names(side_colors)) {
decorate_row_title(nm, {
grid.lines(x = unit(0.1, "npc"),
y = unit(c(0.02, 0.98), "npc"),
gp = gpar(lwd = 6, col = side_colors[nm]))
})
}
# 6. 关闭设备
dev.off()
message(paste("Successfully saved:", filepath))
}
# ========== 使用示例 ==========
# 1. 准备热图
h1 <- build_projection_ht(mat_ipsi_t,   "IPSI",   "Ipsilateral", dend, order = 1)
h2 <- build_projection_ht(mat_contra_t, "CONTRA", "Contralateral", dend, order = 2)
# 2. 垂直拼接
final_list <- h1 %v% h2
# 3. 一键出图（自动保存到 figures/ 文件夹）
render_projection_plot(final_list, "Comparison_3_Layers.pdf", "251637_summary_projection_plot")
# load data and precalculated clustering result
file_results <- "tables/251637_results_v5.xlsx"
cluster_info <- readRDS("tables/clustering_results.rds")
dend <- as.dendrogram(cluster_info$hclust_obj)
sheets <- excel_sheets(file_results)
print(sheets)
#load sheets and combine into new one
proj_df_ipsi <- read_excel(file_results, sheet = "Projection_Strength_L3_ipsi")
proj_df_contra <- read_excel(file_results, sheet = "Projection_Strength_L3_contra")
summary <-  read_excel(file_results, sheet = "Summary")
#arrange into cluster order
proj_df_ipsi_c <- merge(proj_df_ipsi,cluster_info$cluster_df %>% select(-BioType),by='NeuronID') %>% relocate(c(Cluster,DendroOrder),.after=2) %>% arrange(DendroOrder)
proj_df_ipsi_c_s <- merge (proj_df_ipsi_c ,summary %>% select('NeuronID','Soma_Region','Soma_Side'),by='NeuronID') %>% relocate(Soma_Region, Soma_Side, .after = 'NeuronID')
proj_df_contra_c <- merge(proj_df_contra,cluster_info$cluster_df %>% select(-BioType),by='NeuronID') %>% relocate(c(Cluster,DendroOrder),.after=2) %>% arrange(DendroOrder)
proj_df_contra_c_s <- merge (proj_df_contra_c ,summary %>% select('NeuronID','Soma_Region','Soma_Side'),by='NeuronID') %>% relocate(Soma_Region, Soma_Side, .after = 'NeuronID')
# make matrices, here they are aligned with dendroorder already.
meta_cols <- 6
mat_ipsi_t <- t(proj_df_ipsi_c_s%>%
select(-(1:meta_cols)) %>%
as.matrix())
colnames(mat_ipsi_t) <- proj_df_ipsi_c_s$NeuronID
mat_contra_t <- t(proj_df_contra_c_s %>%
select(-(1:meta_cols)) %>%
as.matrix())
colnames(mat_contra_t) <- proj_df_contra_c_s$NeuronID
cluster_vec_ordered <- proj_df_ipsi_c $Cluster
n_clusters <- length(unique(cluster_vec_ordered))
neuron_types <- proj_df_ipsi_c$Neuron_Type
real_order <- unique(proj_df_ipsi_c$Cluster)
slice_types <- sapply(real_order, function(g) {
# 直接去排好序的表里找这个 Cluster 对应的类型
proj_df_ipsi_c$Neuron_Type[proj_df_ipsi_c$Cluster == g][1]
})
type_colors <- c(
"ITc" = "#4DAF4A", "ITs" = "#984EA3", "CT" = "#FF7F00",
"PT" = "#FFFF33", "ITi" = "#E41A1C"
)
# define fill in colours
ha_top <- HeatmapAnnotation(
Type = anno_block(
gp = gpar(fill = type_colors[slice_types], col = "black"),
labels = slice_types,
labels_gp=gpar(fontsize=8),
height = unit(0.6, "cm")
),
Subtype = anno_block(
gp = gpar(fill = "grey90"),
labels = paste0("#", 1:n_clusters),
labels_gp=gpar(fontsize=7),
height = unit(0.2, "cm")
)
)
# --- 核心包装函数：统一所有热图样式 ---
build_projection_ht <- function(mat, name, title,
target_dend = dend,
order = 1,
n_split = 12) {
is_first <- (order == 1)
max_val=max(rowMaxs(mat))
Heatmap(
mat,
name = name,
row_title = title,
col = colorRamp2(c(0, max_val/2, max_val), c("#F7FBF0", "blue", "darkblue"))
,
cluster_rows = FALSE,
row_title_side = "right",
cluster_columns = target_dend,
column_split = n_split,
show_column_dend = is_first,
column_dend_height = unit(4, "cm"),
top_annotation = if(is_first) ha_top else NULL,
column_title = NULL,
column_gap = unit(0.5, "mm"),
show_column_names = FALSE,
border = TRUE
)
}
# --- 自动化保存与装饰函数（改进版）---
render_projection_plot <- function(ht_list, filename, title,
w = 20, h = 15,
folder = "figures") {  # 新增：输出文件夹参数
# 1. 自动创建 figures 文件夹（如果不存在）
if (!dir.exists(folder)) {
dir.create(folder, showWarnings = FALSE, recursive = TRUE)
message(paste("Created folder:", folder))
}
# 2. 拼接完整路径
filepath <- file.path(folder, filename)
# 3. 打开 PDF 设备
pdf(filepath, width = w, height = h)
# 4. 统一绘图配置
draw(ht_list,
column_title = title,
column_title_gp = gpar(fontsize = 16, fontface = "bold"),
show_heatmap_legend = FALSE,
padding = unit(c(15, 5, 25, 50), "mm"))
# 5. 侧边装饰线
side_colors <- c("IPSI" = "#377EB8", "CONTRA" = "#E41A1C")
for(nm in names(side_colors)) {
decorate_row_title(nm, {
grid.lines(x = unit(0.1, "npc"),
y = unit(c(0.02, 0.98), "npc"),
gp = gpar(lwd = 6, col = side_colors[nm]))
})
}
# 6. 关闭设备
dev.off()
message(paste("Successfully saved:", filepath))
}
# ========== 使用示例 ==========
# 1. 准备热图
h1 <- build_projection_ht(mat_ipsi_t,   "IPSI",   "Ipsilateral", dend, order = 1)
h2 <- build_projection_ht(mat_contra_t, "CONTRA", "Contralateral", dend, order = 2)
# 2. 垂直拼接
final_list <- h1 %v% h2
# 3. 一键出图（自动保存到 figures/ 文件夹）
render_projection_plot(final_list, "Comparison_3_Layers.pdf", "251637_summary_projection_plot")
# 可选：自定义文件夹
# render_projection_plot(final_list, "plot.pdf", "Title", folder = "output/figures")
# first merge projection
merged_proj <- full_join(
proj_df_ipsi,
proj_df_contra %>% select(-Neuron_Type),
by = "NeuronID",
suffix = c("_ipsi", "_contra")
)
overlapped_regions <- setdiff(
intersect(names(proj_df_ipsi), names(proj_df_contra %>% select(-Neuron_Type))),
"NeuronID"
)
for(region in overlapped_regions) {
col_i <- paste0(region, "_ipsi")
col_c <- paste0(region, "_contra")
merged_proj[[region]] <- replace_na(merged_proj[[col_i]], 0) +
replace_na(merged_proj[[col_c]], 0)
merged_proj[[col_i]] <- NULL
merged_proj[[col_c]] <- NULL
}
#then merge soma laterality
merged_proj_soma <- merge (merged_proj,summary %>% select('NeuronID','Soma_Region','Soma_Side'),by='NeuronID') %>% relocate(Soma_Region, Soma_Side, .after = NeuronID)
laterality <- summary
proj_df_left_hemisphere <-
#arrange into cluster order
proj_df_ipsi_clustered <- merge(proj_df_ipsi,cluster_info$cluster_df %>% select(-BioType),by='NeuronID') %>% relocate(c(Cluster,DendroOrder),.after=2) %>% arrange(DendroOrder)
proj_df_contra_clustered <- merge(proj_df_contra,cluster_info$cluster_df %>% select(-BioType),by='NeuronID') %>% relocate(c(Cluster,DendroOrder),.after=2) %>% arrange(DendroOrder)
extract_lr_projections <- function(proj_df_ipsi, proj_df_contra, summary_df,
neuron_id_col = "NeuronID",
soma_region_col = "Soma_Region",
soma_side_col = "Soma_Side") {
# --- 1. 准备 summary 数据（选择关键列，移除重复）---
summary_core <- summary_df %>%
select(all_of(c(neuron_id_col, soma_region_col, soma_side_col))) %>%
distinct(across(all_of(neuron_id_col)), .keep_all = TRUE)
# --- 2. 为 IPSI 和 CONTRA 添加 Soma 信息 ---
# Left neurons
ipsi_L <- proj_df_ipsi %>%
inner_join(
summary_core %>% filter(!!sym(soma_side_col) == "L"),
by = neuron_id_col
) %>%
mutate(Projection_Side = "IPSI", Neuron_Group = "L")
contra_L <- proj_df_contra %>%
inner_join(
summary_core %>% filter(!!sym(soma_side_col) == "L"),
by = neuron_id_col
) %>%
mutate(Projection_Side = "CONTRA", Neuron_Group = "L")
# Right neurons
ipsi_R <- proj_df_ipsi %>%
inner_join(
summary_core %>% filter(!!sym(soma_side_col) == "R"),
by = neuron_id_col
) %>%
mutate(Projection_Side = "IPSI", Neuron_Group = "R")
contra_R <- proj_df_contra %>%
inner_join(
summary_core %>% filter(!!sym(soma_side_col) == "R"),
by = neuron_id_col
) %>%
mutate(Projection_Side = "CONTRA", Neuron_Group = "R")
# --- 3. 合并 L 和 R 的数据（长格式）---
combined_L <- bind_rows(ipsi_L, contra_L)
combined_R <- bind_rows(ipsi_R, contra_R)
# --- 4. 创建宽格式矩阵（用于热图）---
# 识别投射列（非元数据列）
meta_cols <- c(neuron_id_col, soma_region_col, soma_side_col,
"Projection_Side", "Neuron_Group")
projection_cols <- setdiff(names(proj_df_ipsi), neuron_id_col)
# L 矩阵：行=神经元，列=目标脑区，值=投射强度
# 分开 IPSI 和 CONTRA 作为两个矩阵
mat_L_ipsi <- ipsi_L %>%
select(all_of(c(neuron_id_col, all_of(projection_cols)))) %>%
column_to_rownames(var = neuron_id_col) %>%
as.matrix()
mat_L_contra <- contra_L %>%
select(all_of(c(neuron_id_col, all_of(projection_cols)))) %>%
column_to_rownames(var = neuron_id_col) %>%
as.matrix()
mat_R_ipsi <- ipsi_R %>%
select(all_of(c(neuron_id_col, all_of(projection_cols)))) %>%
column_to_rownames(var = neuron_id_col) %>%
as.matrix()
mat_R_contra <- contra_R %>%
select(all_of(c(neuron_id_col, all_of(projection_cols)))) %>%
column_to_rownames(var = neuron_id_col) %>%
as.matrix()
# --- 5. 返回结构化的结果 ---
return(list(
# 原始数据框
df_L = combined_L,
df_R = combined_R,
# 分开的 IPSI/CONTRA 数据框（带元数据）
ipsi_L_df = ipsi_L,
contra_L_df = contra_L,
ipsi_R_df = ipsi_R,
contra_R_df = contra_R,
# 矩阵（用于热图）
matrices = list(
L_ipsi = mat_L_ipsi,
L_contra = mat_L_contra,
R_ipsi = mat_R_ipsi,
R_contra = mat_R_contra
),
# 元信息
meta = list(
n_L = nrow(ipsi_L),  # 左神经元数量（IPSI 和 CONTRA 应该相同）
n_R = nrow(ipsi_R),
regions = projection_cols,
soma_regions_L = unique(ipsi_L[[soma_region_col]]),
soma_regions_R = unique(ipsi_R[[soma_region_col]])
)
))
}
lr_data <- extract_lr_projections(
proj_df_ipsi = proj_df_ipsi,
proj_df_contra = proj_df_contra,
summary_df = summary
)
extract_lr_projections <- function(proj_df_ipsi, proj_df_contra, summary_df,
neuron_id_col = "NeuronID",
