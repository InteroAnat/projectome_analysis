#load library
library(readxl)
library(pheatmap)
library(ComplexHeatmap)
library(openxlsx)
library(circlize)
library(grid)
library(dplyr)
# load data and precalculated clustering result
file_results <- "251637_results_v4.xlsx"
file_clustered <- "251637_results_clustered_k9_spearman_penalty.xlsx"
proj_df_ipsi <- read_excel(file_results, sheet = "Projection_Strength_L3_ipsi")
proj_df_contra <- read_excel(file_results, sheet = "Projection_Strength_L3_contra")
cluster_info <- readRDS("clustering_results.rds")
proj_df_ipsi_clustered <- merge(proj_df_ipsi,cluster_info$cluster_df %>% select(-BioType),by='NeuronID') %>% relocate(c(Cluster,DendroOrder),.after=2) %>% arrange(DendroOrder)
proj_df_contra_clustered <- merge(proj_df_contra,cluster_info$cluster_df %>% select(-BioType),by='NeuronID') %>% relocate(c(Cluster,DendroOrder),.after=2) %>% arrange(DendroOrder)
# make matrices
meta_cols <- 4
mat_ipsi <- proj_df_ipsi_clustered %>%
select(-(1:meta_cols)) %>%
as.matrix()
rownames(mat_ipsi) <- proj_df_ipsi_clustered$NeuronID
mat_contra <- proj_df_contra_clustered %>%
select(-(1:meta_cols)) %>%
as.matrix()
rownames(mat_contra) <- proj_df_contra_clustered$NeuronID
mat_ipsi_t <- t(mat_ipsi)
mat_contra_t <- t(mat_contra)
n_neurons <- ncol(mat_ipsi_t)
# 1. 获取 type_vec
type_vec <- proj_df_ipsi_clustered$Neuron_Type
# 2. 获取 cluster_levels（必须在前面定义）
cluster_levels <- unique(proj_df_ipsi_clustered$Cluster)
# 3. 获取每个 cluster 的 Type（使用 sapply/lapply）
type_per_cluster <- sapply(cluster_levels, function(cl) {
# cl 是 sapply 传入的每个 cluster 值
types <- type_vec[cluster_vec == cl]  # 选出该 cluster 的所有 Type
names(sort(table(types), decreasing = TRUE))[1]  # 返回众数
})
# 查看结果
print(type_per_cluster)
# ========== 5. 颜色设置 ==========
type_colors <- c(
"ITc" = "#4DAF4A",  # 绿色
"ITs" = "#984EA3",  # 紫色
"CT"  = "#FF7F00",  # 橙色
"PT"  = "#FFFF33",  # 黄色
"ITi" = "#E41A1C"   # 红色
)
ha_top <- HeatmapAnnotation(
Type = anno_block(
gp = gpar(
fill = type_colors[type_per_cluster[cluster_levels]],
col = "black",
lwd = 0.5
),
labels = type_per_cluster[cluster_levels],
labels_gp = gpar(col = "white", fontsize = 9, fontface = "bold"),
height = unit(0.6, "cm")
),
# 第二层：Subtype 编号（#1, #2, #3...）
Subtype = anno_block(
gp = gpar(fill = "grey90", col = "grey50", lwd = 0.5),
labels = paste0("#", 1:n_clusters),
labels_gp = gpar(fontsize = 8),
height = unit(0.5, "cm")
),
gap = unit(1, "mm")
)
library(dendextend)
library(ComplexHeatmap)
# 1. 获取 hclust 和 DendroOrder
hc <- cluster_info$hclust_obj
dendro_df <- cluster_info$cluster_df  # 有 NeuronID, DendroOrder, Cluster
# 2. 按 DendroOrder 排序（1, 2, 3...）
dendro_df_sorted <- dendro_df %>% arrange(DendroOrder)
# 3. 目标顺序：DendroOrder 对应的 NeuronID
target_order <- dendro_df_sorted$NeuronID  # 按 1, 2, 3... 排列的 ID
# 4. 转换并重新排序 dendrogram
dend <- as.dendrogram(hc)
dend_reordered <- rotate(dend, target_order)  # 关键：旋转叶子到目标顺序
# 验证
labels(dend_reordered)[1:10]  # 应该匹配 target_order[1:10]
# [1] "001.swc" "002.swc" "007.swc" "008.swc" ... （按 DendroOrder 1,2,3...）
ha_top <- HeatmapAnnotation(
Type = anno_block(
gp = gpar(fill = type_colors[type_per_cluster], col = "black", lwd = 0.5),
labels = type_per_cluster,
labels_gp = gpar(col = "white", fontsize = 9, fontface = "bold"),
height = unit(0.6, "cm")
),
Subtype = anno_block(
gp = gpar(fill = "grey90", col = "grey50"),
labels = paste0("#", 1:length(cluster_levels)),
labels_gp = gpar(fontsize = 8),
height = unit(0.5, "cm")
),
gap = unit(1, "mm")
)
ht_ipsi <- Heatmap(
mat_ipsi_t,
name = "Ipsi",
col = colorRamp2(c(0, 2, 4, 6, 8), c("white", "lightyellow", "skyblue", "blue", "navy")),
# 关键：用重新排序的 dendrogram
cluster_columns = dend_reordered,
# 按 cluster 分块，但保持 DendroOrder 内的顺序
column_split = cluster_factor,
cluster_column_slices = FALSE,
top_annotation = ha_top,
show_column_names = FALSE,
cluster_rows = FALSE,
row_names_gp = gpar(fontsize = 8),
row_title = "Ipsilateral",
column_title = NULL
)
ht_ipsi <- Heatmap(
mat_ipsi_t,
name = "Ipsi",
col = colorRamp2(c(0, 2, 4, 6, 8), c("white", "lightyellow", "skyblue", "blue", "navy")),
# 关键：用重新排序的 dendrogram
cluster_columns = FALSE,
# 按 cluster 分块，但保持 DendroOrder 内的顺序
column_split = cluster_factor,
cluster_column_slices = FALSE,
top_annotation = ha_top,
show_column_names = FALSE,
cluster_rows = FALSE,
row_names_gp = gpar(fontsize = 8),
row_title = "Ipsilateral",
column_title = NULL
)
ht_contra <- Heatmap(
mat_contra_t,
name = "Contra",
col = colorRamp2(c(0, 2, 4, 6, 8), c("white", "lightyellow", "skyblue", "blue", "navy")),
cluster_columns = FALSE,  # 顺序已由 dend_reordered 确定
column_split = cluster_factor,
cluster_column_slices = FALSE,
top_annotation = NULL,
show_column_names = FALSE,
cluster_rows = FALSE,
row_names_gp = gpar(fontsize = 8),
row_title = "Contralateral",
column_title = NULL
)
# 拼接
ht_list <- ht_ipsi %v% ht_contra
draw(ht_list)
