select(all_of(c(neuron_id_col, all_of(projection_cols)))) %>%
column_to_rownames(var = neuron_id_col) %>%
as.matrix()
mat_R_contra <- contra_R %>%
select(all_of(c(neuron_id_col, all_of(projection_cols)))) %>%
column_to_rownames(var = neuron_id_col) %>%
as.matrix()
# --- 5. 返回结构化的结果 ---
return(list(
# 原始数据框
df_L = combined_L,
df_R = combined_R,
# 分开的 IPSI/CONTRA 数据框（带元数据）
ipsi_L_df = ipsi_L,
contra_L_df = contra_L,
ipsi_R_df = ipsi_R,
contra_R_df = contra_R,
# 矩阵（用于热图）
matrices = list(
L_ipsi = mat_L_ipsi,
L_contra = mat_L_contra,
R_ipsi = mat_R_ipsi,
R_contra = mat_R_contra
),
# 元信息
meta = list(
n_L = nrow(ipsi_L),  # 左神经元数量（IPSI 和 CONTRA 应该相同）
n_R = nrow(ipsi_R),
regions = projection_cols,
soma_regions_L = unique(ipsi_L[[soma_region_col]]),
soma_regions_R = unique(ipsi_R[[soma_region_col]])
)
))
}
